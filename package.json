{
  "name": "omnimark-language",
  "displayName": "OmniMark Language Support",
  "description": "Syntax highlighting, snippets, and hover documentation for OmniMark (.xom, .xin, .xmd)",
  "version": "1.1.0",
  "publisher": "ppfjuni",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": ["omnimark", "xom", "xin", "xmd", "sgml", "xml", "stilo"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ppedr/ominmark-vscode-extension"
  },
  "activationEvents": [
    "onLanguage:omnimark"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "omnimark",
        "aliases": ["OmniMark", "omnimark"],
        "extensions": [".xom", ".xin", ".xmd", ".xar"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "omnimark",
        "scopeName": "source.omnimark",
        "path": "./syntaxes/omnimark.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "omnimark",
        "path": "./snippets/omnimark.json"
      }
    ]
  }
}
